#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_CONFIG="${ROOT_DIR}/init/config/default.env"
CONFIG_FILE="${URV_CONFIG:-${DEFAULT_CONFIG}}"

if [[ -f "${CONFIG_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${CONFIG_FILE}"
fi

UPSTREAM_REPO="${1:-${UPSTREAM_REPO:-https://github.com/Jman-Github/universal-revanced-manager.git}}"
UPSTREAM_REF="${2:-${UPSTREAM_REF:-${BRANCH_ID:-main}}}"
WORK_DIR="${WORK_DIR:-${ROOT_DIR}/.work/upstream}"
OUT_DIR="${OUT_DIR:-${ROOT_DIR}/out}"
PATCH_MANIFEST="${PATCH_MANIFEST:-${ROOT_DIR}/init/mods.yml}"
GRADLE_TASK="${GRADLE_TASK:-assembleDebug}"
GRADLE_BOOTSTRAP_ARGS="${GRADLE_BOOTSTRAP_ARGS:--PsignAsDebug}"
WARNING_AUTOPATCH="${WARNING_AUTOPATCH:-1}"
WARNING_AUTOPATCH_RETRY="${WARNING_AUTOPATCH_RETRY:-1}"
WARNING_AUTOPATCH_STRICT="${WARNING_AUTOPATCH_STRICT:-0}"
RUN_BUILD="${RUN_BUILD:-1}"
RUN_MODS="${RUN_MODS:-1}"

case "${WORK_DIR}" in /*) ;; *) WORK_DIR="${ROOT_DIR}/${WORK_DIR}" ;; esac
case "${OUT_DIR}" in /*) ;; *) OUT_DIR="${ROOT_DIR}/${OUT_DIR}" ;; esac
case "${PATCH_MANIFEST}" in /*) ;; *) PATCH_MANIFEST="${ROOT_DIR}/${PATCH_MANIFEST}" ;; esac

log() {
  printf '[URV] %s\n' "$*"
}

die() {
  printf '[URV][ERR] %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

run_hooks() {
  local stage="$1"
  local hook_dir="${ROOT_DIR}/init/hooks/${stage}.d"

  [[ -d "${hook_dir}" ]] || return 0

  export ROOT_DIR WORK_DIR OUT_DIR UPSTREAM_REPO UPSTREAM_REF PATCH_MANIFEST GRADLE_TASK GRADLE_BOOTSTRAP_ARGS WARNING_AUTOPATCH WARNING_AUTOPATCH_RETRY WARNING_AUTOPATCH_STRICT RUN_BUILD RUN_MODS

  shopt -s nullglob
  local hook
  for hook in "${hook_dir}"/*; do
    [[ -f "${hook}" ]] || continue
    case "${hook}" in
      *.sh)
        log "hook:${stage}: $(basename "${hook}")"
        bash "${hook}"
        ;;
      *)
        if [[ -x "${hook}" ]]; then
          log "hook:${stage}: $(basename "${hook}")"
          "${hook}"
        fi
        ;;
    esac
  done
  shopt -u nullglob
}

clone_upstream() {
  rm -rf "${WORK_DIR}"
  mkdir -p "$(dirname "${WORK_DIR}")"

  log "clone: ${UPSTREAM_REPO} @ ${UPSTREAM_REF}"

  if git clone --depth 1 --branch "${UPSTREAM_REF}" "${UPSTREAM_REPO}" "${WORK_DIR}"; then
    return 0
  fi

  log "branch clone failed; trying generic clone + checkout"
  git clone --depth 1 "${UPSTREAM_REPO}" "${WORK_DIR}"
  git -C "${WORK_DIR}" fetch --depth 1 origin "${UPSTREAM_REF}" || die "Cannot fetch ref: ${UPSTREAM_REF}"
  git -C "${WORK_DIR}" checkout --detach FETCH_HEAD
}

setup_project() {
  log "setup project"
  mkdir -p "${OUT_DIR}"

  if [[ -n "${ANDROID_HOME:-}" || -n "${ANDROID_SDK_ROOT:-}" ]]; then
    local sdk="${ANDROID_HOME:-${ANDROID_SDK_ROOT:-}}"
    printf 'sdk.dir=%s\n' "${sdk}" > "${WORK_DIR}/local.properties"
  fi

  if [[ -f "${WORK_DIR}/gradlew" ]]; then
    chmod +x "${WORK_DIR}/gradlew"
  fi

  if [[ -f "${WORK_DIR}/gradlew" ]]; then
    (cd "${WORK_DIR}" && ./gradlew --version >/dev/null)
  fi
}

apply_mods() {
  [[ "${RUN_MODS}" == "1" ]] || {
    log "mods disabled"
    return 0
  }

  [[ -f "${PATCH_MANIFEST}" ]] || {
    log "manifest missing: ${PATCH_MANIFEST}; skipping mods"
    return 0
  }

  need_cmd python3
  if ! python3 -c 'import yaml' >/dev/null 2>&1; then
    log "install PyYAML"
    python3 -m pip install --user 'PyYAML>=6.0,<7.0'
  fi

  log "apply mods: ${PATCH_MANIFEST}"
  python3 "${ROOT_DIR}/init/tools/apply_mods.py" \
    --repo "${WORK_DIR}" \
    --manifest "${PATCH_MANIFEST}" \
    --root "${ROOT_DIR}"
}

run_gradle_once() {
  local label="$1"
  shift
  local log_file="$1"
  shift
  mkdir -p "$(dirname "${log_file}")"
  log "gradle:${label}: $*"
  set +e
  (cd "${WORK_DIR}" && "$@") 2>&1 | tee "${log_file}"
  local status=${PIPESTATUS[0]}
  set -e
  return "${status}"
}

run_warning_autopatcher_from_log() {
  local log_file="$1"
  local report_file="$2"
  [[ "${WARNING_AUTOPATCH}" == "1" ]] || return 1
  [[ -f "${ROOT_DIR}/init/tools/kotlin_warning_autopatcher.py" ]] || return 1
  [[ -f "${log_file}" ]] || return 1
  grep -q '^w: file://' "${log_file}" || return 1
  python3 "${ROOT_DIR}/init/tools/kotlin_warning_autopatcher.py" \
    --repo "${WORK_DIR}" \
    --log "${log_file}" \
    --report "${report_file}"
  grep -q '"path"' "${report_file}" 2>/dev/null
}

build_project() {
  [[ "${RUN_BUILD}" == "1" ]] || {
    log "build disabled"
    return 0
  }

  if [[ ! -f "${WORK_DIR}/gradlew" ]]; then
    log "no gradlew detected; skipping Gradle build"
    return 0
  fi

  local -a extra_args=()
  if [[ -n "${GRADLE_BOOTSTRAP_ARGS}" ]]; then
    # shellcheck disable=SC2206
    extra_args=( ${GRADLE_BOOTSTRAP_ARGS} )
  fi

  local log_dir="${OUT_DIR}/logs"
  local first_log="${log_dir}/gradle-build-1.log"
  local second_log="${log_dir}/gradle-build-2.log"
  local report_file="${OUT_DIR}/warning-autopatch-from-log.json"

  run_gradle_once "first" "${first_log}" ./gradlew clean "${GRADLE_TASK}" "${extra_args[@]}" --stacktrace
  local first_status=$?

  local patched=1
  run_warning_autopatcher_from_log "${first_log}" "${report_file}" && patched=0 || patched=1

  if [[ "${patched}" == "0" && "${WARNING_AUTOPATCH_RETRY}" == "1" ]]; then
    log "warning autopatcher changed source; retrying Gradle once"
    run_gradle_once "retry" "${second_log}" ./gradlew "${GRADLE_TASK}" "${extra_args[@]}" --stacktrace
    local retry_status=$?
    if [[ "${WARNING_AUTOPATCH_STRICT}" == "1" ]] && grep -q '^w: file://' "${second_log}"; then
      die "warnings remain after warning autopatch retry; see ${second_log}"
    fi
    return "${retry_status}"
  fi

  if [[ "${WARNING_AUTOPATCH_STRICT}" == "1" ]] && grep -q '^w: file://' "${first_log}"; then
    die "warnings remain and autopatcher made no changes; see ${first_log}"
  fi

  return "${first_status}"
}

collect_outputs() {
  log "collect outputs"
  local log_backup=""
  if [[ -d "${OUT_DIR}/logs" ]]; then
    log_backup="$(mktemp -d)"
    cp -a "${OUT_DIR}/logs" "${log_backup}/logs"
  fi
  local prebuild_report=""
  if [[ -f "${OUT_DIR}/warning-autopatch-prebuild.json" ]]; then
    prebuild_report="$(mktemp)"
    cp "${OUT_DIR}/warning-autopatch-prebuild.json" "${prebuild_report}"
  fi
  local log_report=""
  if [[ -f "${OUT_DIR}/warning-autopatch-from-log.json" ]]; then
    log_report="$(mktemp)"
    cp "${OUT_DIR}/warning-autopatch-from-log.json" "${log_report}"
  fi

  rm -rf "${OUT_DIR}"
  mkdir -p "${OUT_DIR}"

  if [[ -n "${log_backup}" && -d "${log_backup}/logs" ]]; then
    cp -a "${log_backup}/logs" "${OUT_DIR}/logs"
  fi
  if [[ -n "${prebuild_report}" && -f "${prebuild_report}" ]]; then
    cp "${prebuild_report}" "${OUT_DIR}/warning-autopatch-prebuild.json"
  fi
  if [[ -n "${log_report}" && -f "${log_report}" ]]; then
    cp "${log_report}" "${OUT_DIR}/warning-autopatch-from-log.json"
  fi

  if [[ -d "${WORK_DIR}/app/build/outputs" ]]; then
    mkdir -p "${OUT_DIR}/app-build-outputs"
    cp -a "${WORK_DIR}/app/build/outputs/." "${OUT_DIR}/app-build-outputs/"
  fi

  if [[ -d "${WORK_DIR}/build/outputs" ]]; then
    mkdir -p "${OUT_DIR}/root-build-outputs"
    cp -a "${WORK_DIR}/build/outputs/." "${OUT_DIR}/root-build-outputs/"
  fi

  git -C "${WORK_DIR}" rev-parse HEAD > "${OUT_DIR}/upstream-commit.txt" 2>/dev/null || true
  {
    printf 'UPSTREAM_REPO=%s\n' "${UPSTREAM_REPO}"
    printf 'UPSTREAM_REF=%s\n' "${UPSTREAM_REF}"
    printf 'GRADLE_TASK=%s\n' "${GRADLE_TASK}"
    printf 'GRADLE_BOOTSTRAP_ARGS=%s\n' "${GRADLE_BOOTSTRAP_ARGS}"
    printf 'WARNING_AUTOPATCH=%s\n' "${WARNING_AUTOPATCH}"
    printf 'WARNING_AUTOPATCH_RETRY=%s\n' "${WARNING_AUTOPATCH_RETRY}"
    printf 'WARNING_AUTOPATCH_STRICT=%s\n' "${WARNING_AUTOPATCH_STRICT}"
    printf 'RUN_BUILD=%s\n' "${RUN_BUILD}"
    printf 'RUN_MODS=%s\n' "${RUN_MODS}"
  } > "${OUT_DIR}/build-meta.env"

  tar -C "${WORK_DIR}" \
    --exclude='.git' \
    --exclude='.gradle' \
    --exclude='build' \
    --exclude='*/build' \
    -czf "${OUT_DIR}/modified-source.tar.gz" .
}

main() {
  need_cmd git
  need_cmd tar

  run_hooks pre-clone
  clone_upstream
  run_hooks post-clone

  run_hooks pre-setup
  setup_project
  run_hooks post-setup

  run_hooks pre-mods
  apply_mods
  run_hooks post-mods

  run_hooks pre-build
  build_project
  run_hooks post-build

  run_hooks pre-upload
  collect_outputs
  run_hooks post-upload

  log "done: ${OUT_DIR}"
}

main "$@"
