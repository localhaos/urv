#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_CONFIG="${ROOT_DIR}/init/config/default.env"
CONFIG_FILE="${URV_CONFIG:-${DEFAULT_CONFIG}}"

if [[ -f "${CONFIG_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${CONFIG_FILE}"
fi

UPSTREAM_REPO="${1:-${UPSTREAM_REPO:-https://github.com/Jman-Github/universal-revanced-manager.git}}"
UPSTREAM_REF="${2:-${UPSTREAM_REF:-${BRANCH_ID:-main}}}"
WORK_DIR="${WORK_DIR:-${ROOT_DIR}/.work/upstream}"
OUT_DIR="${OUT_DIR:-${ROOT_DIR}/out}"
PATCH_MANIFEST="${PATCH_MANIFEST:-${ROOT_DIR}/init/mods.yml}"
GRADLE_TASK="${GRADLE_TASK:-assembleDebug}"
GRADLE_BOOTSTRAP_ARGS="${GRADLE_BOOTSTRAP_ARGS:--PsignAsDebug}"
START_STAGE="${START_STAGE:-${RESUME_STAGE:-STAGE_1}}"
STOP_AFTER_STAGE="${STOP_AFTER_STAGE:-${STOP_STAGE:-STAGE_9}}"
ARTIFACTS_APPROVED="${ARTIFACTS_APPROVED:-${APPROVED_ARTIFACTS:-0}}"
HIJACKING_OVERLAY="${HIJACKING_OVERLAY:-1}"
CMAKE_PATCHER="${CMAKE_PATCHER:-1}"
NATIVE_PATCHER="${NATIVE_PATCHER:-1}"
JVM_PATCHER="${JVM_PATCHER:-1}"
RESOURCE_FIXER="${RESOURCE_FIXER:-1}"
GRADLE_PATCHER="${GRADLE_PATCHER:-${GRADLE_AUTOFIX:-1}}"
GRADLE_AUTOFIX="${GRADLE_AUTOFIX:-${GRADLE_PATCHER}}"
WARNING_AUTOPATCH="${WARNING_AUTOPATCH:-1}"
WARNING_AUTOPATCH_RETRY="${WARNING_AUTOPATCH_RETRY:-1}"
WARNING_AUTOPATCH_STRICT="${WARNING_AUTOPATCH_STRICT:-0}"
SOURCE_TAR="${SOURCE_TAR:-0}"
SOURCE_TAR_TIMEOUT_SECONDS="${SOURCE_TAR_TIMEOUT_SECONDS:-60}"
SOURCE_TAR_MAX_MB="${SOURCE_TAR_MAX_MB:-80}"
RUN_BUILD="${RUN_BUILD:-1}"
RUN_MODS="${RUN_MODS:-1}"

case "${WORK_DIR}" in /*) ;; *) WORK_DIR="${ROOT_DIR}/${WORK_DIR}" ;; esac
case "${OUT_DIR}" in /*) ;; *) OUT_DIR="${ROOT_DIR}/${OUT_DIR}" ;; esac
case "${PATCH_MANIFEST}" in /*) ;; *) PATCH_MANIFEST="${ROOT_DIR}/${PATCH_MANIFEST}" ;; esac

STAGES_DIR="${ROOT_DIR}/init/STAGES"
APPROVED_ARTIFACTS_MANIFEST="${APPROVED_ARTIFACTS_MANIFEST:-${OUT_DIR}/approved-artifacts.env}"

log() {
  printf '[URV] %s\n' "$*"
}

die() {
  printf '[URV][ERR] %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

parse_stage() {
  local raw="${1:-1}"
  raw="${raw^^}"
  raw="${raw#STAGE_}"
  raw="${raw#0}"
  [[ -n "${raw}" ]] || raw="0"
  [[ "${raw}" =~ ^[0-9]+$ ]] || die "Invalid stage value: $1"
  local n=$((10#${raw}))
  (( n >= 1 && n <= 9 )) || die "Stage out of range 1..9: $1"
  printf '%s\n' "${n}"
}

START_STAGE_NUM="$(parse_stage "${START_STAGE}")"
STOP_STAGE_NUM="$(parse_stage "${STOP_AFTER_STAGE}")"
(( START_STAGE_NUM <= STOP_STAGE_NUM )) || die "START_STAGE must be <= STOP_AFTER_STAGE"

stage_name() {
  printf 'STAGE_%s' "$1"
}

stage_label() {
  case "$1" in
    1) printf 'pre-clone' ;;
    2) printf 'clone' ;;
    3) printf 'post-clone' ;;
    4) printf 'setup' ;;
    5) printf 'mods' ;;
    6) printf 'pre-build' ;;
    7) printf 'build' ;;
    8) printf 'post-build' ;;
    9) printf 'collect' ;;
    *) printf 'unknown' ;;
  esac
}

approval_manifest_ok() {
  [[ -f "${APPROVED_ARTIFACTS_MANIFEST}" ]] || return 1
  grep -Eq '^APPROVED=(1|true|yes)$' "${APPROVED_ARTIFACTS_MANIFEST}"
}

artifacts_approved() {
  [[ "${ARTIFACTS_APPROVED}" =~ ^(1|true|yes)$ ]] && return 0
  approval_manifest_ok
}

validate_resume_gate() {
  if (( START_STAGE_NUM > 1 )); then
    artifacts_approved || die "Refusing resume from $(stage_name "${START_STAGE_NUM}"): set ARTIFACTS_APPROVED=1 or create ${APPROVED_ARTIFACTS_MANIFEST} with APPROVED=1"
  fi
  if (( START_STAGE_NUM >= 3 )); then
    [[ -d "${WORK_DIR}" ]] || die "Cannot resume from $(stage_name "${START_STAGE_NUM}"): WORK_DIR missing: ${WORK_DIR}"
  fi
  if (( START_STAGE_NUM >= 7 )); then
    [[ -x "${WORK_DIR}/gradlew" ]] || die "Cannot resume from $(stage_name "${START_STAGE_NUM}"): gradlew missing/not executable in ${WORK_DIR}"
  fi
}

write_stage_status() {
  local n="$1"
  local state="$2"
  local label
  label="$(stage_label "${n}")"
  mkdir -p "${OUT_DIR}/stage-status"
  {
    printf 'STAGE=%s\n' "$(stage_name "${n}")"
    printf 'LABEL=%s\n' "${label}"
    printf 'STATE=%s\n' "${state}"
    printf 'UPSTREAM_REPO=%s\n' "${UPSTREAM_REPO}"
    printf 'UPSTREAM_REF=%s\n' "${UPSTREAM_REF}"
  } > "${OUT_DIR}/stage-status/$(stage_name "${n}").env"
}

run_stage() {
  local n="$1"
  local label="$2"
  shift 2
  if (( n < START_STAGE_NUM || n > STOP_STAGE_NUM )); then
    log "stage:skip: $(stage_name "${n}") ${label}"
    return 0
  fi
  export CURRENT_STAGE_ID="${n}"
  export CURRENT_STAGE="$(stage_name "${n}")"
  export CURRENT_STAGE_LABEL="${label}"
  log "stage:start: ${CURRENT_STAGE} ${label}"
  write_stage_status "${n}" "started"
  "$@"
  write_stage_status "${n}" "completed"
  log "stage:done: ${CURRENT_STAGE} ${label}"
}

run_hooks() {
  local stage="$1"
  local hook_dir="${ROOT_DIR}/init/hooks/${stage}.d"

  [[ -d "${hook_dir}" ]] || return 0

  export ROOT_DIR WORK_DIR OUT_DIR UPSTREAM_REPO UPSTREAM_REF PATCH_MANIFEST GRADLE_TASK GRADLE_BOOTSTRAP_ARGS START_STAGE STOP_AFTER_STAGE ARTIFACTS_APPROVED APPROVED_ARTIFACTS_MANIFEST HIJACKING_OVERLAY CMAKE_PATCHER NATIVE_PATCHER JVM_PATCHER RESOURCE_FIXER GRADLE_PATCHER GRADLE_AUTOFIX WARNING_AUTOPATCH WARNING_AUTOPATCH_RETRY WARNING_AUTOPATCH_STRICT SOURCE_TAR SOURCE_TAR_TIMEOUT_SECONDS SOURCE_TAR_MAX_MB RUN_BUILD RUN_MODS CURRENT_STAGE CURRENT_STAGE_ID CURRENT_STAGE_LABEL

  shopt -s nullglob
  local hook
  for hook in "${hook_dir}"/*; do
    [[ -f "${hook}" ]] || continue
    case "${hook}" in
      *.sh)
        log "hook:${stage}: $(basename "${hook}")"
        bash "${hook}"
        ;;
      *)
        if [[ -x "${hook}" ]]; then
          log "hook:${stage}: $(basename "${hook}")"
          "${hook}"
        fi
        ;;
    esac
  done
  shopt -u nullglob
}

clone_upstream() {
  rm -rf "${WORK_DIR}"
  mkdir -p "$(dirname "${WORK_DIR}")"

  log "clone: ${UPSTREAM_REPO} @ ${UPSTREAM_REF}"

  if git clone --depth 1 --branch "${UPSTREAM_REF}" "${UPSTREAM_REPO}" "${WORK_DIR}"; then
    return 0
  fi

  log "branch clone failed; trying generic clone + checkout"
  git clone --depth 1 "${UPSTREAM_REPO}" "${WORK_DIR}"
  git -C "${WORK_DIR}" fetch --depth 1 origin "${UPSTREAM_REF}" || die "Cannot fetch ref: ${UPSTREAM_REF}"
  git -C "${WORK_DIR}" checkout --detach FETCH_HEAD
}

setup_project() {
  log "setup project"
  mkdir -p "${OUT_DIR}"

  if [[ -n "${ANDROID_HOME:-}" || -n "${ANDROID_SDK_ROOT:-}" ]]; then
    local sdk="${ANDROID_HOME:-${ANDROID_SDK_ROOT:-}}"
    printf 'sdk.dir=%s\n' "${sdk}" > "${WORK_DIR}/local.properties"
  fi

  if [[ -f "${WORK_DIR}/gradlew" ]]; then
    chmod +x "${WORK_DIR}/gradlew"
  fi

  if [[ -f "${WORK_DIR}/gradlew" ]]; then
    (cd "${WORK_DIR}" && ./gradlew --version >/dev/null)
  fi
}

apply_mods() {
  [[ "${RUN_MODS}" == "1" ]] || {
    log "mods disabled"
    return 0
  }

  [[ -f "${PATCH_MANIFEST}" ]] || {
    log "manifest missing: ${PATCH_MANIFEST}; skipping mods"
    return 0
  }

  need_cmd python3
  if ! python3 -c 'import yaml' >/dev/null 2>&1; then
    log "install PyYAML"
    python3 -m pip install --user 'PyYAML>=6.0,<7.0'
  fi

  log "apply mods: ${PATCH_MANIFEST}"
  python3 "${ROOT_DIR}/init/tools/apply_mods.py" \
    --repo "${WORK_DIR}" \
    --manifest "${PATCH_MANIFEST}" \
    --root "${ROOT_DIR}"
}

run_stage_setup() {
  run_hooks pre-setup
  setup_project
  run_hooks post-setup
}

run_stage_mods() {
  run_hooks pre-mods
  apply_mods
  run_hooks post-mods
}

run_stage_collect() {
  run_hooks pre-upload
  collect_outputs
  run_hooks post-upload
}

run_gradle_once() {
  local label="$1"
  shift
  local log_file="$1"
  shift
  mkdir -p "$(dirname "${log_file}")"
  log "gradle:${label}: $*"
  set +e
  (cd "${WORK_DIR}" && "$@") 2>&1 | tee "${log_file}"
  local status=${PIPESTATUS[0]}
  set -e
  return "${status}"
}

report_has_changes() {
  local report_file="$1"
  python3 - "$report_file" <<'PY'
import json, sys
p = sys.argv[1]
try:
    data = json.load(open(p, encoding='utf-8'))
except Exception:
    raise SystemExit(1)
if isinstance(data, list):
    raise SystemExit(0 if data else 1)
raise SystemExit(0 if data.get('changed') else 1)
PY
}

run_warning_autopatcher_from_log() {
  local log_file="$1"
  local report_file="$2"
  [[ "${WARNING_AUTOPATCH}" == "1" ]] || return 1
  [[ -f "${ROOT_DIR}/init/tools/kotlin_warning_autopatcher.py" ]] || return 1
  [[ -f "${log_file}" ]] || return 1
  grep -q '^w: file://' "${log_file}" || return 1
  python3 "${ROOT_DIR}/init/tools/kotlin_warning_autopatcher.py" \
    --repo "${WORK_DIR}" \
    --log "${log_file}" \
    --report "${report_file}"
  report_has_changes "${report_file}"
}

run_cmake_patcher_from_log() {
  local log_file="$1"
  local report_file="$2"
  [[ "${CMAKE_PATCHER}" == "1" ]] || return 1
  [[ -f "${ROOT_DIR}/init/tools/cmake_patcher.py" ]] || return 1
  [[ -f "${log_file}" ]] || return 1
  grep -Eq 'CMake|configureCMake|buildCMake|externalNativeBuild|ninja:|CMAKE_|CMakeCache|build.ninja' "${log_file}" || return 1
  python3 "${ROOT_DIR}/init/tools/cmake_patcher.py" \
    --repo "${WORK_DIR}" \
    --log "${log_file}" \
    --report "${report_file}"
  report_has_changes "${report_file}"
}

run_resource_fixer_from_log() {
  local log_file="$1"
  local report_file="$2"
  [[ "${RESOURCE_FIXER}" == "1" ]] || return 1
  [[ -f "${ROOT_DIR}/init/tools/patcher_resource_fixer.py" ]] || return 1
  [[ -f "${log_file}" ]] || return 1
  grep -Eiq 'without required default value|Android resource linking failed|AAPT:|aapt2|error: resource|res/values' "${log_file}" || return 1
  python3 "${ROOT_DIR}/init/tools/patcher_resource_fixer.py" \
    --repo "${WORK_DIR}" \
    --log "${log_file}" \
    --report "${report_file}"
  report_has_changes "${report_file}"
}

run_gradle_patcher_from_log() {
  local log_file="$1"
  local report_file="$2"
  [[ "${GRADLE_PATCHER}" == "1" ]] || return 1
  [[ -f "${ROOT_DIR}/init/tools/gradle_patcher.py" ]] || return 1
  [[ -f "${log_file}" ]] || return 1
  grep -Eq '^[ew]: file://|Deprecated Gradle features|Observed package id|without required default value' "${log_file}" || return 1
  python3 "${ROOT_DIR}/init/tools/gradle_patcher.py" \
    --repo "${WORK_DIR}" \
    --log "${log_file}" \
    --report "${report_file}"
  report_has_changes "${report_file}"
}

build_project() {
  [[ "${RUN_BUILD}" == "1" ]] || {
    log "build disabled"
    return 0
  }

  if [[ ! -f "${WORK_DIR}/gradlew" ]]; then
    log "no gradlew detected; skipping Gradle build"
    return 0
  fi

  local -a extra_args=()
  if [[ -n "${GRADLE_BOOTSTRAP_ARGS}" ]]; then
    # shellcheck disable=SC2206
    extra_args=( ${GRADLE_BOOTSTRAP_ARGS} )
  fi

  local log_dir="${OUT_DIR}/logs"
  local first_log="${log_dir}/gradle-build-1.log"
  local second_log="${log_dir}/gradle-build-2.log"
  local warning_report="${OUT_DIR}/warning-autopatch-from-log.json"
  local cmake_report="${OUT_DIR}/gradle-patcher-cmake-from-log.json"
  local resource_report="${OUT_DIR}/gradle-patcher-resource-from-log.json"
  local gradle_report="${OUT_DIR}/gradle-patcher-from-log.json"

  set +e
  run_gradle_once "first" "${first_log}" ./gradlew clean "${GRADLE_TASK}" "${extra_args[@]}" --stacktrace
  local first_status=$?
  set -e

  local patched=1
  run_cmake_patcher_from_log "${first_log}" "${cmake_report}" && patched=0 || true
  run_resource_fixer_from_log "${first_log}" "${resource_report}" && patched=0 || true
  run_gradle_patcher_from_log "${first_log}" "${gradle_report}" && patched=0 || true
  run_warning_autopatcher_from_log "${first_log}" "${warning_report}" && patched=0 || true

  if [[ "${patched}" == "0" && "${WARNING_AUTOPATCH_RETRY}" == "1" ]]; then
    log "patcher changed source; retrying Gradle once"
    set +e
    run_gradle_once "retry" "${second_log}" ./gradlew "${GRADLE_TASK}" "${extra_args[@]}" --stacktrace
    local retry_status=$?
    set -e
    if [[ "${WARNING_AUTOPATCH_STRICT}" == "1" ]] && grep -Eq '^[we]: file://' "${second_log}"; then
      die "diagnostics remain after patcher retry; see ${second_log}"
    fi
    return "${retry_status}"
  fi

  if [[ "${WARNING_AUTOPATCH_STRICT}" == "1" ]] && grep -Eq '^[we]: file://' "${first_log}"; then
    die "diagnostics remain and patcher made no changes; see ${first_log}"
  fi

  return "${first_status}"
}

write_source_manifest() {
  [[ -d "${WORK_DIR}" ]] || return 0
  log "source manifest"
  (
    cd "${WORK_DIR}"
    find . \
      \( -path './.git' -o -path './.git/*' -o -path './.gradle' -o -path './.gradle/*' -o -path './build' -o -path './build/*' -o -path './.cxx' -o -path './.cxx/*' -o -path './.kotlin' -o -path './.kotlin/*' -o -path './.idea' -o -path './.idea/*' -o -path './captures' -o -path './captures/*' -o -path './*/build' -o -path './*/build/*' -o -path './*/.cxx' -o -path './*/.cxx/*' \) -prune \
      -o -type f -printf '%P\t%s\n' | sort
  ) > "${OUT_DIR}/modified-source-files.tsv" || true
}

maybe_create_source_tar() {
  [[ "${SOURCE_TAR}" == "1" ]] || {
    log "source tar disabled; set SOURCE_TAR=1 to create modified-source.tar.gz"
    return 0
  }
  [[ -d "${WORK_DIR}" ]] || return 0

  local tar_file="${OUT_DIR}/modified-source.tar.gz"
  local tar_log="${OUT_DIR}/modified-source-tar.log"
  local timeout_cmd=(timeout "${SOURCE_TAR_TIMEOUT_SECONDS}s")
  if ! command -v timeout >/dev/null 2>&1; then
    timeout_cmd=()
  fi

  log "source tar: creating ${tar_file} with timeout ${SOURCE_TAR_TIMEOUT_SECONDS}s"
  set +e
  "${timeout_cmd[@]}" tar -C "${WORK_DIR}" \
    --exclude='.git' \
    --exclude='.gradle' \
    --exclude='build' \
    --exclude='*/build' \
    --exclude='.cxx' \
    --exclude='*/.cxx' \
    --exclude='.kotlin' \
    --exclude='*/.kotlin' \
    --exclude='.idea' \
    --exclude='captures' \
    -czf "${tar_file}" . >"${tar_log}" 2>&1
  local status=$?
  set -e
  if [[ "${status}" != "0" ]]; then
    log "source tar skipped/failed with status ${status}; see ${tar_log}"
    rm -f "${tar_file}"
    return 0
  fi

  local bytes max_bytes
  bytes="$(wc -c < "${tar_file}" | tr -d ' ')"
  max_bytes=$(( SOURCE_TAR_MAX_MB * 1024 * 1024 ))
  if (( bytes > max_bytes )); then
    log "source tar too large (${bytes} bytes > ${SOURCE_TAR_MAX_MB} MB); deleting ${tar_file}"
    rm -f "${tar_file}"
    printf 'SOURCE_TAR_SKIPPED=too_large\nSOURCE_TAR_BYTES=%s\nSOURCE_TAR_MAX_MB=%s\n' "${bytes}" "${SOURCE_TAR_MAX_MB}" > "${OUT_DIR}/modified-source-tar.env"
    return 0
  fi
  printf 'SOURCE_TAR_CREATED=1\nSOURCE_TAR_BYTES=%s\nSOURCE_TAR_MAX_MB=%s\n' "${bytes}" "${SOURCE_TAR_MAX_MB}" > "${OUT_DIR}/modified-source-tar.env"
}

collect_outputs() {
  log "collect outputs"
  local log_backup=""
  if [[ -d "${OUT_DIR}/logs" ]]; then
    log_backup="$(mktemp -d)"
    cp -a "${OUT_DIR}/logs" "${log_backup}/logs"
  fi

  local stage_backup=""
  if [[ -d "${OUT_DIR}/stage-status" ]]; then
    stage_backup="$(mktemp -d)"
    cp -a "${OUT_DIR}/stage-status" "${stage_backup}/stage-status"
  fi

  local report_backup="$(mktemp -d)"
  shopt -s nullglob
  local report
  for report in "${OUT_DIR}"/*autopatch*.json "${OUT_DIR}"/*autofix*.json "${OUT_DIR}"/*gradle-patcher*.json "${OUT_DIR}"/*hijacking*.json "${OUT_DIR}"/*tar*.env "${OUT_DIR}"/*tar*.log; do
    [[ -f "${report}" ]] || continue
    cp "${report}" "${report_backup}/$(basename "${report}")"
  done
  shopt -u nullglob

  rm -rf "${OUT_DIR}"
  mkdir -p "${OUT_DIR}"

  if [[ -n "${log_backup}" && -d "${log_backup}/logs" ]]; then
    cp -a "${log_backup}/logs" "${OUT_DIR}/logs"
  fi
  if [[ -n "${stage_backup}" && -d "${stage_backup}/stage-status" ]]; then
    cp -a "${stage_backup}/stage-status" "${OUT_DIR}/stage-status"
  fi
  shopt -s nullglob
  for report in "${report_backup}"/*; do
    [[ -f "${report}" ]] || continue
    cp "${report}" "${OUT_DIR}/$(basename "${report}")"
  done
  shopt -u nullglob

  if [[ -d "${WORK_DIR}/app/build/outputs" ]]; then
    mkdir -p "${OUT_DIR}/app-build-outputs"
    cp -a "${WORK_DIR}/app/build/outputs/." "${OUT_DIR}/app-build-outputs/"
  fi

  if [[ -d "${WORK_DIR}/build/outputs" ]]; then
    mkdir -p "${OUT_DIR}/root-build-outputs"
    cp -a "${WORK_DIR}/build/outputs/." "${OUT_DIR}/root-build-outputs/"
  fi

  git -C "${WORK_DIR}" rev-parse HEAD > "${OUT_DIR}/upstream-commit.txt" 2>/dev/null || true
  write_source_manifest
  maybe_create_source_tar

  {
    printf 'UPSTREAM_REPO=%s\n' "${UPSTREAM_REPO}"
    printf 'UPSTREAM_REF=%s\n' "${UPSTREAM_REF}"
    printf 'START_STAGE=%s\n' "$(stage_name "${START_STAGE_NUM}")"
    printf 'STOP_AFTER_STAGE=%s\n' "$(stage_name "${STOP_STAGE_NUM}")"
    printf 'ARTIFACTS_APPROVED=%s\n' "${ARTIFACTS_APPROVED}"
    printf 'APPROVED_ARTIFACTS_MANIFEST=%s\n' "${APPROVED_ARTIFACTS_MANIFEST}"
    printf 'GRADLE_TASK=%s\n' "${GRADLE_TASK}"
    printf 'GRADLE_BOOTSTRAP_ARGS=%s\n' "${GRADLE_BOOTSTRAP_ARGS}"
    printf 'HIJACKING_OVERLAY=%s\n' "${HIJACKING_OVERLAY}"
    printf 'CMAKE_PATCHER=%s\n' "${CMAKE_PATCHER}"
    printf 'NATIVE_PATCHER=%s\n' "${NATIVE_PATCHER}"
    printf 'JVM_PATCHER=%s\n' "${JVM_PATCHER}"
    printf 'RESOURCE_FIXER=%s\n' "${RESOURCE_FIXER}"
    printf 'GRADLE_PATCHER=%s\n' "${GRADLE_PATCHER}"
    printf 'GRADLE_AUTOFIX=%s\n' "${GRADLE_AUTOFIX}"
    printf 'WARNING_AUTOPATCH=%s\n' "${WARNING_AUTOPATCH}"
    printf 'WARNING_AUTOPATCH_RETRY=%s\n' "${WARNING_AUTOPATCH_RETRY}"
    printf 'WARNING_AUTOPATCH_STRICT=%s\n' "${WARNING_AUTOPATCH_STRICT}"
    printf 'SOURCE_TAR=%s\n' "${SOURCE_TAR}"
    printf 'SOURCE_TAR_TIMEOUT_SECONDS=%s\n' "${SOURCE_TAR_TIMEOUT_SECONDS}"
    printf 'SOURCE_TAR_MAX_MB=%s\n' "${SOURCE_TAR_MAX_MB}"
    printf 'RUN_BUILD=%s\n' "${RUN_BUILD}"
    printf 'RUN_MODS=%s\n' "${RUN_MODS}"
  } > "${OUT_DIR}/build-meta.env"
}

main() {
  need_cmd git
  validate_resume_gate
  mkdir -p "${OUT_DIR}"
  log "stage plan: start=$(stage_name "${START_STAGE_NUM}") stop=$(stage_name "${STOP_STAGE_NUM}") approved=${ARTIFACTS_APPROVED}"

  run_stage 1 "pre-clone" run_hooks pre-clone
  run_stage 2 "clone" clone_upstream
  run_stage 3 "post-clone" run_hooks post-clone
  run_stage 4 "setup" run_stage_setup
  run_stage 5 "mods" run_stage_mods
  run_stage 6 "pre-build" run_hooks pre-build
  run_stage 7 "build" build_project
  run_stage 8 "post-build" run_hooks post-build
  run_stage 9 "collect" run_stage_collect

  log "done: ${OUT_DIR}"
}

main "$@"
