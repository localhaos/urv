# Default bootstrap configuration.
UPSTREAM_REPO="https://github.com/Jman-Github/universal-revanced-manager.git"
UPSTREAM_REF="dev"

WORK_DIR=".work/upstream"
OUT_DIR="out"
PATCH_MANIFEST="init/mods.yml"

# Staged execution. Use START_STAGE=STAGE_5 with ARTIFACTS_APPROVED=1 to resume.
START_STAGE="STAGE_1"
STOP_AFTER_STAGE="STAGE_9"
ARTIFACTS_APPROVED="0"
HIJACKING_OVERLAY="1"

# Avoid pre-upload stalls caused by large modified source archives.
# Set SOURCE_TAR=1 manually when a source snapshot is explicitly needed.
SOURCE_TAR="0"
SOURCE_TAR_TIMEOUT_SECONDS="60"
SOURCE_TAR_MAX_MB="80"

RUN_MODS="1"
RUN_BUILD="1"
GRADLE_TASK="assembleDev"
GRADLE_BOOTSTRAP_ARGS="-PsignAsDebug"
CMAKE_PATCHER="1"
NATIVE_PATCHER="1"
JVM_PATCHER="1"
GRADLE_PATCHER="1"
RESOURCE_FIXER="1"
GRADLE_AUTOFIX="1"
WARNING_AUTOPATCH="1"
WARNING_AUTOPATCH_RETRY="1"
WARNING_AUTOPATCH_STRICT="0"
